{
  "permissions": {
    "allow": [
      "Bash(make build *)",
      "Bash(make lint *)",
      "Bash(make format *)",
      "Bash(hugo version *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make build lint"
          }
        ]
      }
    ]
  }
}
